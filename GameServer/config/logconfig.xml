<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" throwConfigExceptions="true" throwExceptions="true">
	<targets>
		<!-- Console -->
		<target name="console" xsi:type="ColoredConsole"
			layout="${date:format=HH\:mm\:ss} | ${level:uppercase=true:format=TriLetter} | ${logger} | ${message}">
				<highlight-row foregroundColor="Gray" condition="level == LogLevel.Trace" />
				<highlight-row foregroundColor="Blue" condition="level == LogLevel.Debug" />
				<highlight-row foregroundColor="White" condition="level == LogLevel.Info" />
				<highlight-row foregroundColor="Yellow" condition="level == LogLevel.Warn" />
				<highlight-row foregroundColor="Red" condition="level == LogLevel.Error" />
				<highlight-row foregroundColor="DarkRed" condition="level == LogLevel.Fatal" />
				<highlight-row foregroundColor="Magenta" condition="level == LogLevel.Off" />
		</target>

		<!-- Log Files -->
		<target name="gameServerFile" xsi:type="File"
			layout="${date:format=MM/dd HH\:mm\:ss} | ${level:uppercase=true:format=TriLetter} | ${logger} | ${message}"
			fileName="./logs/GameServer.log"
			keepFileOpen="true"
			archiveFileName="./logs/$GameServer.{#}.txt"
			archiveNumbering="DateAndSequence"
			archiveDateFormat="yyyy-MM-dd"
			archiveAboveSize="104857600"
			maxArchiveDays="7" />
		<target name="warnFile" xsi:type="File"
			layout="${date:format=MM/dd HH\:mm\:ss} | ${logger} | ${message}"
			fileName="./logs/Warn.log"
			keepFileOpen="true"
			archiveFileName="./logs/$Warn.{#}.txt"
			archiveNumbering="DateAndSequence"
			archiveDateFormat="yyyy-MM-dd"
			archiveAboveSize="104857600"
			maxArchiveDays="7" />
		<target name="errorFile" xsi:type="File"
			layout="${date:format=MM/dd HH\:mm\:ss} | ${logger} | ${message}"
			fileName="./logs/Error.log"
			keepFileOpen="true"
			archiveFileName="./logs/$Error.{#}.txt"
			archiveNumbering="DateAndSequence"
			archiveDateFormat="yyyy-MM-dd"
			archiveAboveSize="104857600"
			archiveEvery="Day" />
		<target name="gmActionFile" xsi:type="File"
			layout="${date:format=MM/dd HH\:mm\:ss} | ${message}"
			fileName="./logs/GMActions.log" 
			keepFileOpen="true"
			archiveFileName="./logs/$GMActions.{#}.txt"
			archiveNumbering="DateAndSequence"
			archiveDateFormat="yyyy-MM-dd"
			archiveAboveSize="104857600"
			archiveEvery="Day" />
		<target name="cheatFile" xsi:type="File"
			layout="${date:format=MM/dd HH\:mm\:ss} | ${message}"
			fileName="./logs/Cheats.log"
			keepFileOpen="true"
			archiveFileName="./logs/$GameServer.{#}.txt"
			archiveNumbering="DateAndSequence"
			archiveDateFormat="yyyy-MM-dd"
			archiveAboveSize="104857600"
			archiveEvery="Day" />
		<target name="dualIpFile" xsi:type="File"
			layout="${date:format=MM/dd HH\:mm\:ss} | ${message}"
			fileName="./logs/DualIP.log"
			keepFileOpen="true"
			archiveFileName="./logs/$DualIP.{#}.txt"
			archiveNumbering="DateAndSequence"
			archiveDateFormat="yyyy-MM-dd"
			archiveAboveSize="104857600"
			archiveEvery="Day" />
		<target name="inventoryFile" xsi:type="File"
			layout="${date:format=MM/dd HH\:mm\:ss} | ${message}"
			fileName="./logs/Inventories.log"
			keepFileOpen="true"
			archiveFileName="./logs/$Inventories.{#}.txt"
			archiveNumbering="DateAndSequence"
			archiveDateFormat="yyyy-MM-dd"
			archiveAboveSize="104857600"
			archiveEvery="Day" />
		
		<!-- Black Hole -->
		<target name="blackHole"
			xsi:type="Null" />
	</targets>

	<rules>
		<!-- Special Loggers -->
		<logger name="gmactions"
			minLevel="Trace"
			writeTo="gmActionFile"
			final="true" />
		<logger name="cheats"
			minLevel="Trace"
			writeTo="cheatFile"
			final="true" />
		<logger name="dualip"
			minLevel="Trace"
			writeTo="dualIpFile"
			final="true" />
		<logger name="inventories"
			minLevel="Trace"
			writeTo="inventoryFile"
			final="true" />

		<!-- Filters -->
		<logger name="DOL.GS.PacketHandler.PacketProcessor"
			maxlevel="Info"
			writeTo="blackHole"
			final="true" />
		<logger name="DOL.Database.ObjectDatabase"
			maxlevel="Info"
			writeTo="blackHole"
			final="true" />
		<logger name="DOL.GS.GameObject"
			maxlevel="Info"
			writeTo="blackHole"
			final="true" />
		<logger name="DOL.Database.Handlers"
			maxlevel="Info"
			writeTo="blackHole"
			final="true" />
		<logger name="DOL.GS.Zone"
			maxlevel="Info"
			writeTo="blackHole"
			final="true" />
		<logger name="DOL.GS.GameTimer"
			maxlevel="Debug"
			writeTo="blackHole"
			final="true" />
		
		<!-- Global Loggers -->
		<logger name="*"
			minLevel="Debug"
			writeTo="console" />
		<logger name="*"
			minLevel="Debug"
			writeTo="gameServerFile" />
		<logger name="*"
			Level="Warn"
			writeTo="warnFile" />
		<logger name="*"
			Level="Error"
			writeTo="errorFile" />
	</rules>
</nlog>